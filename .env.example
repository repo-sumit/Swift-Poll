# =========================================================
# Swift Poll - environment variables
# =========================================================
# Copy this file to `.env` for local reference. For the
# static frontend, values are read from js/config.js which
# can in turn be generated from these variables, OR you can
# paste them directly into js/config.js (see README).
# =========================================================

# Your Supabase project URL (Project settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public "anon" key - safe to expose in a static frontend
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Slug of the default poll (matches supabase-schema.sql seed)
POLL_SLUG=swift-poll-default

# Optional passcode to gate the dashboard.
# Leave blank to keep dashboard public. If set, user is
# prompted once and the value is stored in localStorage.
DASHBOARD_PASSCODE=
